{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "aliyun-sms-access-key-id": {
      "type": "parameter.v0",
      "value": "{aliyun-sms-access-key-id.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "aliyun-sms-access-key-secret": {
      "type": "parameter.v0",
      "value": "{aliyun-sms-access-key-secret.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "qianwen-api-key": {
      "type": "parameter.v0",
      "value": "{qianwen-api-key.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "redis": {
      "type": "container.v0",
      "connectionString": "{redis.bindings.tcp.host}:{redis.bindings.tcp.port},password={redis-password.value}",
      "image": "docker.io/library/redis:7.4",
      "entrypoint": "/bin/sh",
      "args": [
        "-c",
        "redis-server --requirepass $REDIS_PASSWORD --save 60 1"
      ],
      "volumes": [
        {
          "name": "gonomads.apphost-c829b367d6-redis-data",
          "target": "/data",
          "readOnly": false
        }
      ],
      "env": {
        "REDIS_PASSWORD": "{redis-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 6379
        }
      }
    },
    "rabbitmq": {
      "type": "container.v0",
      "connectionString": "amqp://guest:{rabbitmq-password.value}@{rabbitmq.bindings.tcp.host}:{rabbitmq.bindings.tcp.port}",
      "image": "docker.io/library/rabbitmq:4.0-management",
      "volumes": [
        {
          "name": "gonomads.apphost-c829b367d6-rabbitmq-data",
          "target": "/var/lib/rabbitmq",
          "readOnly": false
        }
      ],
      "env": {
        "RABBITMQ_DEFAULT_USER": "guest",
        "RABBITMQ_DEFAULT_PASS": "{rabbitmq-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5672
        },
        "management": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 15672
        }
      }
    },
    "elasticsearch": {
      "type": "container.v0",
      "connectionString": "http://elastic:{elasticsearch-password.value}@{elasticsearch.bindings.http.host}:{elasticsearch.bindings.http.port}",
      "image": "docker.io/library/elasticsearch:8.17.3",
      "volumes": [
        {
          "name": "gonomads.apphost-c829b367d6-elasticsearch-data",
          "target": "/usr/share/elasticsearch/data",
          "readOnly": false
        }
      ],
      "env": {
        "discovery.type": "single-node",
        "xpack.security.enabled": "true",
        "ELASTIC_PASSWORD": "{elasticsearch-password.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 9200
        },
        "internal": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 9300
        }
      }
    },
    "message-service": {
      "type": "project.v0",
      "path": "../Services/MessageService/MessageService/API/MessageService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "user-service": {
      "type": "project.v0",
      "path": "../Services/UserService/UserService/UserService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "Kestrel__Endpoints__Grpc__Url": "http://*:{user-service.bindings.Grpc.targetPort}",
        "Kestrel__Endpoints__Http__Url": "http://*:{user-service.bindings.Http.targetPort}",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "AliyunSms__AccessKeyId": "{aliyun-sms-access-key-id.value}",
        "AliyunSms__AccessKeySecret": "{aliyun-sms-access-key-secret.value}"
      },
      "bindings": {
        "Grpc": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http2",
          "targetPort": 50002
        },
        "Http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 8080
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http2",
          "targetPort": 50002
        }
      }
    },
    "city-service": {
      "type": "project.v0",
      "path": "../Services/CityService/CityService/CityService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__elasticsearch": "{elasticsearch.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "product-service": {
      "type": "project.v0",
      "path": "../Services/ProductService/ProductService/ProductService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "document-service": {
      "type": "project.v0",
      "path": "../Services/DocumentService/DocumentService/DocumentService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}"
      }
    },
    "coworking-service": {
      "type": "project.v0",
      "path": "../Services/CoworkingService/CoworkingService/CoworkingService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "accommodation-service": {
      "type": "project.v0",
      "path": "../Services/AccommodationService/AccommodationService/AccommodationService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "event-service": {
      "type": "project.v0",
      "path": "../Services/EventService/EventService/EventService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "innovation-service": {
      "type": "project.v0",
      "path": "../Services/InnovationService/InnovationService/InnovationService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "ai-service": {
      "type": "project.v0",
      "path": "../Services/AIService/AIService/AIService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}",
        "ConnectionStrings__QianWenApiKey": "{qianwen-api-key.value}"
      }
    },
    "search-service": {
      "type": "project.v0",
      "path": "../Services/SearchService/SearchService/SearchService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}",
        "ConnectionStrings__rabbitmq": "{rabbitmq.connectionString}",
        "ConnectionStrings__elasticsearch": "{elasticsearch.connectionString}"
      }
    },
    "cache-service": {
      "type": "project.v0",
      "path": "../Services/CacheService/CacheService/CacheService.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__redis": "{redis.connectionString}"
      }
    },
    "gateway": {
      "type": "project.v0",
      "path": "../Gateway/Gateway/Gateway.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "services__user-service__Grpc__0": "{user-service.bindings.Grpc.url}",
        "services__user-service__Http__0": "{user-service.bindings.Http.url}",
        "services__user-service__https__0": "{user-service.bindings.https.url}"
      }
    },
    "redis-password": {
      "type": "parameter.v0",
      "value": "{redis-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "rabbitmq-password": {
      "type": "parameter.v0",
      "value": "{rabbitmq-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "elasticsearch-password": {
      "type": "parameter.v0",
      "value": "{elasticsearch-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    }
  }
}