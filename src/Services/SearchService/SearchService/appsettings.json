{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Elasticsearch": {
    "Url": "http://localhost:5303",
    "DefaultIndex": "gonomads",
    "Username": "",
    "Password": "",
    "EnableDebugMode": true
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration123456",
    "Issuer": "GoNomadsAPI",
    "Audience": "GoNomadsClient",
    "ExpiryMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Elastic": "Warning"
      }
    }
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Username": "walden",
    "Password": "walden"
  },
  "IndexSettings": {
    "CityIndex": "cities",
    "CoworkingIndex": "coworking_spaces",
    "NumberOfShards": 1,
    "NumberOfReplicas": 0
  },
  "IndexMaintenance": {
    "Enabled": true,
    "InitialDelayMinutes": 5,
    "VerifyIntervalMinutes": 60
  },
  "ServiceUrls": {
    "CityService": "http://localhost:5202",
    "CoworkingService": "http://localhost:5203"
  }
}
